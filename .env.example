# 环境变量示例 - 复制为 .env 使用
# .env.example

# Hugging Face 配置
HF_HOME=./models  # 模型缓存目录
HF_ENDPOINT=https://huggingface.co  # 或使用国内镜像: https://hf-mirror.com

# PyTorch 配置
TORCH_HOME=./models  # PyTorch 缓存

# API 配置
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=true

# Gradio 配置
GRADIO_SERVER_NAME=127.0.0.1
GRADIO_SERVER_PORT=7860

# 模型配置
MODEL_DEVICE=cuda  # cuda 或 cpu
MODEL_DTYPE=float16  # float16 或 float32
MODEL_ID=runwayml/stable-diffusion-v1-5
LCM_LORA_ID=latent-consistency/lcm-lora-sdv1-5

# 生成配置
DEFAULT_GUIDANCE_SCALE=7.5
DEFAULT_STEPS=8
DEFAULT_SEED=-1

# 日志配置
LOG_LEVEL=INFO

# 背景移除方法
BG_REMOVAL_METHOD=rembg  # rembg 或 sam

# 输出配置
OUTPUT_DIR=./output
MAX_OUTPUT_SIZE=4096  # 最大输出尺寸像素

# ==================== 七牛云企业级配置 ====================
# 七牛云对象存储配置
QINIU_ACCESS_KEY=your_qiniu_access_key_here
QINIU_SECRET_KEY=your_qiniu_secret_key_here
QINIU_BUCKET=game-assets-prod
QINIU_CDN_DOMAIN=assets.yourgame.com
QINIU_REGION=z0  # z0=华东, z1=华北, z2=华南, na0=北美, as0=东南亚

# 风格缓存配置
STYLE_CACHE_ENABLED=true
STYLE_CACHE_TTL_DAYS=30
STYLE_CACHE_SYNC_TO_KODO=false  # 是否自动同步到七牛云

# 项目配置
DEFAULT_PROJECT_ID=default_project
DEFAULT_PROJECT_NAME=My Game Project
